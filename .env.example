# ==========================================
# Application Environment Variables Example
# ==========================================

# ------------------------------------------
# Backend (Spring Boot) Configuration
# ------------------------------------------
# Port for the Spring Boot server
SERVER_PORT=8080

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/algorithm_visualizer?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=password

# CORS Configuration
# Adjust this if your frontend runs on a different port/domain in production
ALLOWED_ORIGINS=http://localhost:5173

# ------------------------------------------
# Frontend (React/Vite) Configuration
# ------------------------------------------
# API URL for backend communication
VITE_API_BASE_URL=http://localhost:8080/api/algorithms
